# ─── Supabase ───────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose to client

# ─── Paystack ────────────────────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com → Settings → API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxx   # safe for client
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxx               # server-side ONLY
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret            # from Paystack dashboard

# ─── VTU Provider (VTU.ng) ────────────────────────────────────────────────
# Get from: https://vtu.ng → API Documentation
VTU_API_KEY=your-vtu-ng-api-key
VTU_BASE_URL=https://api.vtu.ng/v1
VTU_USERNAME=your-vtu-ng-username

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VaultPay
